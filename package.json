{
  "name": "embyhub",
  "version": "1.2.0",
  "description": "Web-based Emby user management system with Telegram Bot",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start:bot": "node src/bot/index.js",
    "start:all": "concurrently \"npm start\" \"npm run start:bot\"",
    "dev": "nodemon src/index.js",
    "dev:bot": "nodemon src/bot/index.js",
    "test": "jest",
    "lint": "eslint src/"
  },
  "keywords": [
    "emby",
    "media-server",
    "user-management",
    "telegram-bot",
    "web-interface",
    "invitation-system",
    "mysql"
  ],
  "author": "KyrieM",
  "license": "Apache-2.0",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "mysql2": "^3.6.5",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "axios": "^1.6.2",
    "node-telegram-bot-api": "^0.64.0",
    "concurrently": "^8.2.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "xss": "^1.0.14",
    "validator": "^13.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "eslint": "^8.55.0"
  }
}
