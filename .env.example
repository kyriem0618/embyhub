# EmbyHub 环境变量配置

# 服务端口
PORT=3000

# Emby 服务器配置
EMBY_URL=http://your-emby-server:8096
EMBY_API_KEY=your-emby-api-key

# JWT 密钥（生产环境请修改）
JWT_SECRET=change-this-to-a-random-string

# MySQL 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=embyhub
DB_PASSWORD=your-mysql-password
DB_NAME=embyhub

# Telegram Bot (可选)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=