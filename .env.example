# EmbyHub Configuration

# ============ Emby Server ============
EMBY_URL=http://localhost:8096
EMBY_API_KEY=your-api-key-here

# ============ Application ============
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# ============ Database ============
# 开发环境用 SQLite，生产环境用 MySQL
DB_TYPE=sqlite  # sqlite | mysql

# SQLite 配置
DB_PATH=./data/embyhub.db

# MySQL 配置 (生产环境)
DB_HOST=localhost
DB_PORT=3306
DB_USER=embyhub
DB_PASSWORD=your-password
DB_NAME=embyhub

# ============ JWT ============
JWT_SECRET=change-this-secret-key-in-production
JWT_EXPIRES_IN=7d

# ============ Telegram Bot ============
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_WEBHOOK_URL=https://your-domain.com/bot/webhook
TELEGRAM_ADMIN_IDS=123456789,987654321  # 管理员 Telegram ID，逗号分隔

# ============ Session ============
SESSION_TIMEOUT=3600000
